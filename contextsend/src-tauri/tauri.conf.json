{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ContextSend",
  "version": "0.1.0",
  "identifier": "dev.contextsend.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ContextSend 上下文分享",
        "width": 960,
        "height": 680,
        "minWidth": 300,
        "minHeight": 500,
        "resizable": true,
        "decorations": false,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; img-src 'self' asset: data: blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "局域网内分享本地 Chat AI 上下文",
    "longDescription": "ContextSend 从本地 Chat AI 应用提取对话上下文，并在局域网中向配对设备安全分享。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
